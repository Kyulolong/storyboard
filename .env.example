# ── 이미지 생성 provider: "mock"(기본,비용0) | "pollinations"(무료) | "replicate" | "fal"
NEXT_PUBLIC_IMAGE_PROVIDER=mock
REPLICATE_API_TOKEN=
FAL_KEY=

# ── 텍스트 자동생성 provider: "none"(끔) | "groq"
# Groq 무료 키 발급: https://console.groq.com/keys (카드 불필요)
NEXT_PUBLIC_TEXT_PROVIDER=none
GROQ_API_KEY=

# 위 키들은 서버(app/api/*)에서만 사용되며 브라우저에 노출되지 않습니다.
