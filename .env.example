# ── 이미지 생성 provider ──────────────────────────────────────────────
# "mock"(기본,비용0) | "pollinations"(무료,키불필요) | "gemini" | "openai" | "replicate" | "fal"
NEXT_PUBLIC_IMAGE_PROVIDER=mock

# ── 텍스트 자동생성 provider ──────────────────────────────────────────
# "none"(끔) | "groq"(무료) | "gemini"(무료 한도) | "openai"(유료)
NEXT_PUBLIC_TEXT_PROVIDER=none

# ── API 키 (선택) ─────────────────────────────────────────────────────
# 여기에 키를 넣으면 서버가 그 키로 대신 호출한다(자체 호스팅/개인용).
# 비워두면 BYOK 모드: 사용자가 화면에서 자기 키를 넣어 쓴다.
#   - 사용자 키는 요청 헤더로만 오고, 그 요청 안에서만 쓰고 버린다.
#   - 서버에 저장하지 않고 로그에도 남기지 않는다.
#   - 브라우저에서는 sessionStorage에만 있어서 탭을 닫으면 사라진다.
# 공개 배포라면 키를 비워두는 쪽(BYOK)을 권한다 — 남의 키를 넘겨받지 않는 게 가장 안전하다.
# 쓰는 서비스의 키만 넣으면 된다. 텍스트/이미지가 같은 키를 공유한다.
# Groq 무료 키: https://console.groq.com/keys        (카드 불필요)
GROQ_API_KEY=
# Gemini 키: https://aistudio.google.com/apikey      (무료 한도 있음)
GEMINI_API_KEY=
# OpenAI 키: https://platform.openai.com/api-keys    (유료, 크레딧 필요)
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
FAL_KEY=

# ── 모델 지정 (선택) ──────────────────────────────────────────────────
# 비워두면 아래 기본값을 쓴다. 모델명이 바뀌면 코드 수정 없이 여기서 교체.
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# OPENAI_MODEL=gpt-5.6-luna
# OPENAI_IMAGE_MODEL=gpt-image-2

# ── 요청 제한 (선택) ──────────────────────────────────────────────────
# 프로덕션에서만 켜진다(로컬은 자동으로 꺼짐). 분당 IP 기준 허용 횟수.
# 서버 키로 도는 요청은 운영자가 돈을 내므로 더 빡세게, 사용자가 자기 키를
# 넣은 요청(BYOK)은 본인이 내므로 넉넉하게 잡는다.
# ⚠ 카운터가 프로세스 메모리에 있어서 서버리스처럼 인스턴스가 여러 개면
#   인스턴스마다 따로 센다. 정확한 쿼터가 아니라 과속방지턱이다.
# RATE_GENERATE_SERVER=5     # 서버 키로 콘티 생성 (분당)
# RATE_GENERATE_BYOK=20      # 사용자 키로 콘티 생성 (분당)
# RATE_SKETCH_SERVER=30      # 서버 키/키없음으로 그림 생성 (분당)
# RATE_SKETCH_BYOK=120       # 사용자 키로 그림 생성 (분당)
# RATE_LIMIT_DISABLED=1      # 완전히 끄기 (개인 서버)
# RATE_LIMIT_FORCE=1         # 로컬에서도 켜기 (테스트용)

# ── 베이스 URL 덮어쓰기 (선택) ────────────────────────────────────────
# 사내 프록시/게이트웨이(LiteLLM, Azure 등)를 태울 때만 쓴다.
# GROQ_BASE_URL=
# GEMINI_BASE_URL=
# OPENAI_BASE_URL=

# 위 키들은 서버(app/api/*)에서만 사용되며 브라우저에 노출되지 않습니다.
